<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net462;net8.0</TargetFrameworks>
    <IsPackable>False</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Update="App_Data\SerialNumber.db3">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="$(TargetFramework.Equals('net462'))">
    <Reference Include="System.Configuration" />
  </ItemGroup>

  <ItemGroup Condition="$(TargetFramework.Equals('net8.0'))">
    <EmbeddedResource Include="App.config" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.11" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="4.0.2" />
    <PackageReference Include="MSTest.TestFramework" Version="4.0.2" />
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SD.Common\SD.Common.csproj" />
    <ProjectReference Include="..\SD.Toolkits.SerialNumber\SD.Toolkits.SerialNumber.csproj" />
    <ProjectReference Include="..\SD.Toolkits.SerialNumber.MySql\SD.Toolkits.SerialNumber.MySql.csproj" />
    <ProjectReference Include="..\SD.Toolkits.SerialNumber.PostgreSQL\SD.Toolkits.SerialNumber.PostgreSQL.csproj" />
    <ProjectReference Include="..\SD.Toolkits.SerialNumber.Sqlite\SD.Toolkits.SerialNumber.Sqlite.csproj" />
    <ProjectReference Include="..\SD.Toolkits.SerialNumber.SqlServer\SD.Toolkits.SerialNumber.SqlServer.csproj" />
  </ItemGroup>
</Project>
