<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net462;netstandard2.0;net8.0;net10.0</TargetFrameworks>
    <Description>SD.Toolkits SQL扩展组件 - PostgreSQL实现</Description>
  </PropertyGroup>

  <ItemGroup Condition="$(TargetFramework.Equals('net462')) Or $(TargetFramework.Equals('netstandard2.0'))">
    <PackageReference Include="Npgsql" Version="8.0.9" />
  </ItemGroup>

  <ItemGroup Condition="$(TargetFramework.Equals('net8.0')) Or $(TargetFramework.Equals('net10.0'))">
    <PackageReference Include="Npgsql" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SD.Toolkits.Sql\SD.Toolkits.Sql.csproj" />
  </ItemGroup>
</Project>
